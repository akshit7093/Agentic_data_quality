            "description": "Price per unit"
        },
        {
            "name": "total_amount",
            "type": "REAL",
            "description": "Total order value"
        },
        {
            "name": "order_date",
            "type": "TIMESTAMP",
            "description": "Time of order"
        },
        {
            "name": "shipping_address",
            "type": "TEXT",
            "description": "Delivery address"
        },
        {
            "name": "status",
            "type": "TEXT",
            "description": "Order status (Pending, Shipped, etc.)"
        },
        {
            "name": "discount_code",
            "type": "TEXT",
            "description": "Applied promo code"
        }
