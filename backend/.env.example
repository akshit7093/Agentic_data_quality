# AI Data Quality Agent - Environment Configuration

# Application Settings
DEBUG=false
APP_NAME="AI Data Quality Agent"
APP_VERSION="1.0.0"
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database Settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dataquality
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
# Options: ollama, lmstudio, openai, anthropic
LLM_PROVIDER=ollama

# Ollama Settings (Local LLM - Recommended)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LM Studio Settings
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_API_KEY=lm-studio

# OpenAI Settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Anthropic Settings
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini Settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_RPM_LIMIT=15
GEMINI_TPM_LIMIT=250000
GEMINI_RPD_LIMIT=2000
GEMINI_COOLDOWN_SEC=4.0

# Groq Settings (Comma-separated for round-robin)
GROQ_API_KEYS=key1,key2
GROQ_MODEL=llama-3.2-90b-vision-preview

# OpenRouter Settings (Comma-separated for round-robin)
OPENROUTER_API_KEYS=key1,key2
OPENROUTER_MODEL=deepseek/deepseek-r1

# Embedding Settings
VECTOR_DB_PATH=./chroma_db

# Validation Settings
MAX_SAMPLE_SIZE=10000
DEFAULT_SAMPLE_SIZE=1000
MAX_CONTEXT_TOKENS=128000

# Azure Settings (Optional)
AZURE_STORAGE_ACCOUNT=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# AWS Settings (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# GCP Settings (Optional)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PROJECT_ID=

# Databricks Settings (Optional)
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# CORS Settings
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
